  <!-- Client-side Scripts for Real-time telemetry, Chandelier interactions, and Interactive Labs -->
  <script is:inline>
    // -------------------------------------------------------------
    // Background Drifting Particles Canvas
    // -------------------------------------------------------------
    const canvas = document.getElementById('quantum-bg');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let width = canvas.width = canvas.parentElement.offsetWidth;
      let height = canvas.height = canvas.parentElement.offsetHeight;

      window.addEventListener('resize', () => {
        if (canvas) {
          width = canvas.width = canvas.parentElement.offsetWidth;
          height = canvas.height = canvas.parentElement.offsetHeight;
        }
      });

      const symbols = ['H', 'X', 'Z', 'S', 'T', 'CNOT', '|0⟩', '|1⟩', '|ψ⟩', '⊕'];
      const particles = [];
      for (let i = 0; i < 40; i++) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          text: symbols[Math.floor(Math.random() * symbols.length)],
          size: Math.random() * 12 + 10,
          speedX: (Math.random() - 0.5) * 0.3,
          speedY: -Math.random() * 0.5 - 0.1,
          alpha: Math.random() * 0.4 + 0.1
        });
      }

      function drawBG() {
        ctx.clearRect(0, 0, width, height);
        particles.forEach(p => {
          ctx.save();
          ctx.globalAlpha = p.alpha;
          ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--accent-cyan').trim() || '#0891b2';
          ctx.font = `${p.size}px "Fira Code", monospace`;
          ctx.fillText(p.text, p.x, p.y);
          ctx.restore();

          // update position
          p.x += p.speedX;
          p.y += p.speedY;

          // recycle particle
          if (p.y < -30) {
            p.y = height + 30;
            p.x = Math.random() * width;
          }
        });
        requestAnimationFrame(drawBG);
      }
      drawBG();
    }

    // -------------------------------------------------------------
    // Bidirectional Fridge SVG & Card highlights
    // -------------------------------------------------------------
    const stages = document.querySelectorAll('.fridge-stage');
    const cards = document.querySelectorAll('.layer-wrapper');

    function highlightCards(stageId, active) {
      let layerIds = [];
      if (stageId === '300k') {
        layerIds = ['compilation', 'qudits', 'control', 'classical_control', 'vacuum', 'network'];
      } else if (stageId === '4k') {
        layerIds = ['microwave', 'readout'];
      } else if (stageId === '15mk') {
        layerIds = ['qec', 'qec_topological', 'physics', 'shielding', 'decoherence', 'cryogenics', 'topological_material'];
      }

      layerIds.forEach(id => {
        const c = document.querySelector(`[data-layer-id="${id}"]`);
        if (c) {
          if (active) {
            c.classList.add('stage-highlight');
          } else {
            c.classList.remove('stage-highlight');
          }
        }
      });
    }

    function getStageFromCard(cardId) {
      if (['compilation', 'qudits', 'control', 'classical_control', 'vacuum', 'network'].includes(cardId)) return '300k';
      if (['microwave', 'readout'].includes(cardId)) return '4k';
      if (['qec', 'qec_topological', 'physics', 'shielding', 'decoherence', 'cryogenics', 'topological_material'].includes(cardId)) return '15mk';
      return null;
    }

    stages.forEach(st => {
      st.addEventListener('mouseenter', () => {
        const stageId = st.getAttribute('data-stage');
        st.classList.add('active');
        highlightCards(stageId, true);
      });
      st.addEventListener('mouseleave', () => {
        const stageId = st.getAttribute('data-stage');
        st.classList.remove('active');
        highlightCards(stageId, false);
      });
    });

    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const cardId = card.getAttribute('data-layer-id');
        const stageId = getStageFromCard(cardId);
        if (stageId) {
          const correspondingStages = document.querySelectorAll(`.fridge-stage[data-stage="${stageId}"]`);
          correspondingStages.forEach(s => s.classList.add('active'));
        }
      });
      card.addEventListener('mouseleave', () => {
        const cardId = card.getAttribute('data-layer-id');
        const stageId = getStageFromCard(cardId);
        if (stageId) {
          const correspondingStages = document.querySelectorAll(`.fridge-stage[data-stage="${stageId}"]`);
          correspondingStages.forEach(s => s.classList.remove('active'));
        }
      });
    });

    // Qubit Modality Toggle
    const toggleTransmon = document.getElementById('toggle-transmon');
    const toggleTopological = document.getElementById('toggle-topological');
    const dashboard = document.querySelector('.quantum-dashboard');

    if (toggleTransmon && toggleTopological && dashboard) {
      toggleTransmon.addEventListener('click', () => {
        toggleTransmon.classList.add('active');
        toggleTopological.classList.remove('active');
        dashboard.classList.remove('modality-topological');
      });

      toggleTopological.addEventListener('click', () => {
        toggleTopological.classList.add('active');
        toggleTransmon.classList.remove('active');
        dashboard.classList.add('modality-topological');
      });
    }

  </script>
</Base>
