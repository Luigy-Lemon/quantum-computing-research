---
import Base from '../layouts/Base.astro';
import ChandelierSchematic from '../components/ChandelierSchematic.astro';
import Card from '../components/Card.astro';
import Tag from '../components/Tag.astro';
import Math from '../components/Math.astro';
import InteractiveHero from '../components/InteractiveHero.astro';
import TelemetryBanner from '../components/TelemetryBanner.astro';

const layers = [
  {
    id: 'compilation', num: 1, label: 'Algorithm',
    title: 'Shor\'s Algorithm & Crypto Compilation',
    funny: '"Just factor this 256-bit number" — famous last words. You need ~2,000 logical qubits, each costing ~1,000 physical ones. The math is elegant; the bill is not.',
    challenge: '2,048 logical qubits × 1,000 physical each = a chip the size of a warehouse',
    chips: ['ECDLP → period-finding', 'modular exponentiation', 'ripple-carry adders'],
    theme: 'cyan',
    stage: '300k',
    spec: 'Classical Core Compiler',
    model: 'SHOR-COMP-256',
    math: 'f(x) = a^x \\pmod N'
  },
  {
    id: 'qudits', num: 2, label: 'Optimization',
    title: 'Qutrits, Qudits & Gate Squashing',
    funny: 'What if your qubit could hold more than two values? Qutrits add a |2⟩ state, slashing Toffoli counts. Like discovering your apartment has a basement — free real estate, if the floor holds.',
    challenge: 'Higher states decay faster, leak out of the error correction code, and need exquisitely calibrated pulses',
    chips: ['|0⟩ |1⟩ |2⟩', 'Toffoli → 3-pulse CCZ', 'N² → N log N depth'],
    theme: 'accent',
    stage: '300k',
    spec: 'Multi-level Compiler',
    model: 'QUT-DECOMP-3',
    math: '|\\psi\\rangle = \\alpha|0\\rangle + \\beta|1\\rangle + \\gamma|2\\rangle'
  },
  {
    id: 'qec', num: 3, label: 'Error Correction',
    title: 'Topological QEC & Leakage Reduction',
    funny: '1,000 physical qubits per logical qubit. You\'re building a cathedral to protect one bit of information. The Surface Code is the cathedral. Leakage Reduction Units are the pest control.',
    challenge: 'Syndrome extraction + MWPM decoding must finish in ~1 µs — software is too slow, need Cryo-ASICs',
    chips: ['Surface Code d=27', 'syndrome extraction', 'LRC flush circuits'],
    theme: 'pink',
    stage: '15mk',
    spec: 'FPGA Decoder Loop',
    model: 'SURF-QEC-27',
    math: 's_i = \\prod_{j \\in \\mathcal{N}(i)} \\sigma_j^z = \\pm 1'
  },
  {
    id: 'qec_topological', num: 3, label: 'Error Correction',
    title: 'Topological Braiding & Tracking',
    funny: 'Instead of an active QEC loop running at microsecond speeds to correct physical errors, error rates drop exponentially with anyon separation. QEC becomes a software tracking layer, not a hardware bottleneck.',
    challenge: 'Active fast feedback is bypassed. QEC is reduced to passive tracking of anyon braiding on-chip, significantly reducing classical control overhead.',
    chips: ['Braiding-Only Tracking', 'Non-Abelian Anyons', 'Passive Error Suppression'],
    theme: 'pink',
    stage: '15mk',
    spec: 'Software Tracking Layer',
    model: 'TOPO-TRACK-01',
    math: 'U_{\\text{braid}} \\psi_i = \\sum_{j} R_{ij} \\psi_j'
  },
  {
    id: 'classical_control', num: 4, label: 'Hardware Rack',
    title: 'Room-Temperature Electronics',
    funny: 'If the chandelier is the brain, this rack is the life support. Heavy, noisy, and draws enough power to run a small village.',
    challenge: 'Cabling thousands of coax lines without creating ground loops or thermal leaks.',
    chips: ['FPGA Arrays', 'RFSoC', 'AWG Synthesis', 'Power Supplies'],
    theme: 'green',
    stage: '300k',
    spec: 'Rackmount Control',
    model: '19-INCH-RACK',
    math: '\\text{Data Rate} = N_q \\times f_s \\times B_r'
  },
  {
    id: 'control', num: 5, label: 'Control',
    title: 'Pulse Physics, RFSoC & FPGA Synthesis',
    funny: 'Your gate is a sculpted microwave pulse. The FPGA generates it. The DAC converts it. The fridge delivers it. The qubit ignores half of it because of crosstalk. Quantum computing is basically arguing with a microwave.',
    challenge: '8 GSPS DAC, GRAPE-optimized envelopes, parametric compilation — and still can\'t afford enough FPGA RAM',
    chips: ['Cross-Resonance gates', 'GRAPE optimal control', 'RFSoC 8 GSPS'],
    theme: 'orange',
    stage: '300k',
    spec: 'DAC/ADC RF synthesis',
    model: 'FPGA-PULSE-DRAG',
    math: '\\Omega_q(t) = \\Omega_x(t) - i \\frac{\\Omega_x\'(t)}{2\\Delta_{12}}'
  },
  {
    id: 'microwave', num: 6, label: 'Microwave Wiring',
    title: 'Signal Conditioning & Attenuation',
    funny: 'To prevent room-temperature noise from melting your qubit, you must attenuate the signal by 50 dB. Yes, we throw away 99.999% of our own pulse. It\'s intentional.',
    challenge: 'Johnson-Nyquist thermal noise cascades down the lines, requiring massive attenuators at every temperature stage.',
    chips: ['60dB Attenuation', 'Microwave Isolators', 'Superconducting NbTi', 'IR Filters'],
    theme: 'orange',
    stage: '4k',
    spec: 'Coaxial Infrastructure',
    model: 'RF-COND-50DB',
    math: 'T_{e} = T_0 + \\frac{T_{\\text{room}}}{10^{A/10}}'
  },
  {
    id: 'readout', num: 7, label: 'Readout',
    title: 'QND Measurement & State Discrimination',
    funny: '"Measure without destroying." It\'s like checking if a soufflé has risen by staring through a tiny window. With microwaves. At 15 millikelvin. The soufflé is also quantum.',
    challenge: 'Discriminate d states in <300 ns before T₁ decay smears IQ blobs into noise',
    chips: ['dispersive shift χ', 'TWPA + HEMT chain', '~99.5% fidelity'],
    theme: 'purple',
    stage: '4k',
    spec: 'TWPA + Digitizer',
    model: 'TWPA-DISCR-04',
    math: '\\chi = \\frac{g^2}{\\Delta}'
  },
  {
    id: 'vacuum', num: 8, label: 'Vacuum Systems',
    title: 'Ultra-High Vacuum & Turbo Pumps',
    funny: 'At 15mK, air freezes solid onto your quantum chip, creating dielectric loss. So we pump out the air until the pressure is lower than deep space. Then we hope it doesn\'t leak.',
    challenge: 'Maintaining < 10^-8 mbar vacuum with hundreds of wire feedthroughs.',
    chips: ['Turbo-molecular pump', 'Rotary backing pump', 'Helium leak testing'],
    theme: 'accent-secondary',
    stage: '300k',
    spec: 'Vacuum Environment',
    model: 'UHV-TURBO-V',
    math: 'P = P_0 e^{-(S/V)t}'
  },
  {
    id: 'cryogenics', num: 9, label: 'Cryogenics',
    title: 'Dilution Refrigerators & Thermodynamics',
    funny: '15 millikelvin. Colder than the cosmic microwave background. Your dilution fridge costs $1M, weighs 500 kg, takes 3 days to cool down. The quantum computer runs inside a chandelier that costs more than a house.',
    challenge: 'Each coax cable is a heat pipe — 50 dB attenuation cascade, superconducting NbTi wiring, He-3 scarcity',
    chips: ['He-3/He-4 mixing', '15 mK base', '3-day cooldown'],
    theme: 'orange',
    stage: '15mk',
    spec: 'Thermal Isolation',
    model: 'DRY-FRIDGE-15M',
    math: 'n_{\\text{thermal}} = \\frac{1}{e^{\\hbar\\omega / k_B T} - 1}'
  },
  {
    id: 'shielding', num: 10, label: 'Shielding',
    title: 'Magnetic & Radiation Isolation',
    funny: 'A stray magnetic field from a passing bus or a cosmic ray from a dying star can flip your qubit. We wrap it in μ-metal, cryoperm, and pray.',
    challenge: '1/f flux noise from magnetic impurities and phonon bursts from cosmic ray impacts.',
    chips: ['μ-metal shields', 'Cryoperm', 'Infrared Eccosorb'],
    theme: 'red',
    stage: '15mk',
    spec: 'Environmental Isolation',
    model: 'M-SHIELD-X',
    math: 'B_{\\text{in}} = \\frac{B_{\\text{out}}}{\\mu_r \\cdot t / R}'
  },
  {
    id: 'physics', num: 11, label: 'Qubit',
    title: 'Transmon Physics & Josephson Junctions',
    funny: 'A transmon is a capacitor and a Josephson junction in a tug-of-war. The junction is two pieces of aluminum separated by oxide a few atoms thick. You build a quantum computer out of rusty aluminum. This is not a joke.',
    challenge: 'EJ/EC sweet spot is narrow — too far either way and you lose coherence or addressability',
    chips: ['anharmonic oscillator', 'EJ/EC ≈ 50', '~5 GHz frequency'],
    theme: 'green',
    stage: '15mk',
    spec: 'Superconducting Wafer',
    model: 'JJ-TRANSMON-5G',
    math: '\\hat{H} = 4 E_C (\\hat{n} - n_g)^2 - E_J \\cos(\\hat{\\phi})'
  },
  {
    id: 'decoherence', num: 12, label: 'Decoherence',
    title: 'Microscopic Decoherence Mechanisms',
    funny: 'Your qubit lives ~100 μs. In that window it must be initialized, entangled with 1,000 neighbors, measured, and corrected — thousands of times. A mayfly running a marathon, chased by cosmic rays.',
    challenge: 'TLS defects, quasiparticle poisoning, 1/f flux noise — three independent killers, no cure',
    chips: ['T₁ ~ 100 μs', 'T₂ ~ 150 μs', 'quasiparticle bursts'],
    theme: 'cyan',
    stage: '15mk',
    spec: 'Coherence Boundary',
    model: 'COH-DECAY-T1',
    math: 'P_{\\text{coh}}(t) = e^{-t / T_1} \\cdot e^{-t / T_2}'
  },
  {
    id: 'topological_material', num: '10-12', label: 'Qubit & Materials',
    title: 'Topological Lead-Based Material System (InAs/Pb Nanowire)',
    funny: '"Why correct errors when you can prevent them?" Microsoft\'s Majorana 2 chip uses lead-based (Pb) superconductor shells on indium arsenide (InAs) nanowires to build a pristine, topological protective barrier. Your qubit lifetime jumps from 100 microseconds to 20 seconds. Materials physics is still brutally hard, but you bypass three entire layers of the standard stack.',
    challenge: 'Establishing the lead-based topological gap experimentally is extremely difficult. The signatures are still in preprint, awaiting peer review to confirm they aren\'t just Andreev Bound States.',
    chips: ['InAs/Pb Nanowires', '20s Coherence Time', 'AI-Discovery Protocol', 'Topological Protection'],
    theme: 'teal',
    stage: '15mk',
    spec: 'Lead Superconductor Wafer',
    model: 'MSFT-MAJORANA-2',
    math: '\\Delta_{\\text{top}} = \\sqrt{E_Z^2 - \\Delta_{\\text{sc}}^2}'
  },
  {
    id: 'network', num: 13, label: 'Network',
    title: 'Quantum Interconnects & Transduction',
    funny: 'You ran out of space in the fridge. Now you need to entangle a qubit in this fridge with a qubit in the next fridge using a photon. Good luck converting microwaves to optical without adding noise.',
    challenge: 'Electro-optic transduction efficiency is notoriously low (~10^-4). Need massive improvements to scale out.',
    chips: ['Microwave-to-Optical', 'Entanglement Swapping', 'Optical Fibers'],
    theme: 'purple',
    stage: '300k',
    spec: 'Transduction Link',
    model: 'Q-NET-LINK',
    math: '\\eta = \\frac{\\gamma_{\\text{em}} \\gamma_{\\text{opt}}}{(\\gamma_{\\text{em}} + \\kappa_{\\text{em}})(\\gamma_{\\text{opt}} + \\kappa_{\\text{opt}})}'
  }
];
---

<Base title="Quantum Computing Stack" activeNav="/" mathjax>
  <!-- Page-specific fonts not in global.css -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

  <style>
    :global(body) {
      font-family: 'Space Grotesk', 'Helvetica Neue', sans-serif !important;
    }

    /* Outer Wrapper with dot grid backdrop */
    .quantum-workspace {
      position: relative;
      width: 100%;
      min-height: calc(100vh - 80px);
      padding: 2.5rem 1rem 5rem;
      max-width: 100%;
      margin: 0 auto;
      z-index: 1;
      background-image: radial-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px);
      background-size: 20px 20px;
    }

    /* Drifting background canvas */
    #quantum-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: -1;
      pointer-events: none;
      opacity: 0.12;
    }

    /* Academic Journal Header Style */
    .hero {
      text-align: left;
      padding: 1rem 0 2rem;
      border-bottom: 2px solid var(--border);
      margin-bottom: 2.5rem;
      position: relative;
    }
    .paper-meta {
      font-family: 'Fira Code', monospace;
      font-size: 0.72rem;
      color: var(--text-light);
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
    }
    .hero h1 {
      font-family: 'Orbitron', sans-serif;
      font-size: 3.2rem;
      font-weight: 900;
      color: var(--ink);
      margin-bottom: 0.6rem;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }
    .paper-authors {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      line-height: 1.4;
    }
    .hero-subtitle {
      max-width: 950px;
      font-family: 'Lora', Georgia, serif;
      font-size: 1.05rem;
      color: var(--text-main);
      margin-bottom: 1.5rem;
      line-height: 1.65;
      background: var(--surface-hover);
      padding: 1.25rem 1.5rem;
      border-left: 3px solid var(--accent);
      border-radius: 4px;
    }
    
    /* Telemetry Panel (Oscilloscope CRT Display) */
    .telemetry-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      background: var(--surface-hover);
      border: 2px solid var(--accent-green);
      border-radius: 4px;
      padding: 0.75rem 1.25rem;
      font-family: 'Fira Code', monospace;
      font-size: 0.8rem;
      color: var(--text-main);
      box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.05);
      position: relative;
      overflow: hidden;
    }
    /* CRT Scanline pattern */
    .telemetry-row::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.05) 50%);
      background-size: 100% 4px;
      pointer-events: none;
      z-index: 10;
    }
    .telemetry-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      z-index: 2;
    }
    .telemetry-item strong {
      color: var(--accent-green);
      text-shadow: none;
    }
    .telemetry-indicator {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent-green);
      box-shadow: none;
      display: inline-block;
    }
    .telemetry-indicator.pulsing {
      animation: pulseIndicator 1.5s infinite alternate;
    }

    /* Layout Sections */
    .hero-section {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
    }

    .schematic-section {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto 3rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
    }

    .schematic-hint {
      margin-top: 1rem;
      font-size: 0.73rem;
      color: var(--text-light);
      font-style: italic;
      text-align: center;
    }

    .quantum-dashboard {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      align-items: start;
      margin-top: 2rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--border);
    }

    @media (min-width: 1200px) {
      .quantum-dashboard {
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
      }
      .stack-layers {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.75rem;
      }
    }

    @media (min-width: 1600px) {
      .stack-layers {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* 19-inch Hardware Rack cabinet */

    /* 19-inch Hardware Rack cabinet */
    .rack-cabinet {
      position: relative;
    }

    @media (min-width: 1200px) {
      .rack-cabinet {
        padding: 0 20px;
      }
      /* Left and Right Rack Rails with repeating mounting holes */
      .rack-cabinet::before,
      .rack-cabinet::after {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 12px;
        background: var(--surface-alt);
        border: 1px solid var(--border);
        background-image: radial-gradient(circle, var(--border) 2.5px, transparent 3.5px);
        background-size: 12px 40px;
        z-index: 10;
        box-shadow: inset 1px 0 3px rgba(0,0,0,0.08);
      }
      .rack-cabinet::before {
        left: 0;
        border-radius: 2px 0 0 2px;
      }
      .rack-cabinet::after {
        right: 0;
        border-radius: 0 2px 2px 0;
      }
    }

    .stack-layers {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Card styled as a Rackmount Laboratory Module */
    .layer-wrapper {
      display: block;
      position: relative;
    }
    .layer-wrapper.stage-highlight :global(.card) {
      box-shadow: 0 4px 16px var(--card-accent);
      border-color: var(--card-accent);
      transform: translateY(-2px);
    }

    /* Metal Rack Ears for mounting simulation */
    .rack-ear-left,
    .rack-ear-right {
      display: none;
    }

    @media (min-width: 1200px) {
      .rack-ear-left,
      .rack-ear-right {
        display: flex;
        position: absolute;
        top: -2px;
        bottom: -2px;
        width: 20px;
        background: var(--surface-alt);
        border: 2px solid var(--border);
        z-index: 9;
        align-items: center;
        justify-content: center;
      }
      .rack-ear-left {
        left: -20px;
        border-right: none;
        box-shadow: inset 1px 1px 2px rgba(255,255,255,0.05);
      }
      .rack-ear-right {
        right: -20px;
        border-left: none;
        box-shadow: inset -1px 1px 2px rgba(255,255,255,0.05);
      }
      
      /* Metal mounting screws on ears */
      .screw {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: radial-gradient(circle at 3px 3px, var(--surface) 1px, var(--border) 6px);
        border: 1px solid var(--border);
        position: absolute;
      }
      .screw::after {
        content: '';
        position: absolute;
        width: 8px;
        height: 1px;
        background: var(--border);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(45deg);
      }
      .rack-ear-left .screw { top: 12px; }
      .rack-ear-right .screw { bottom: 12px; }
    }

    /* Content Link layout */
    .layer-content-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 640px) {
      .layer-content-grid {
        grid-template-columns: 140px 1fr;
      }
    }

    .layer-meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      border-right: 0px solid var(--border);
    }
    @media (min-width: 640px) {
      .layer-meta {
        border-right: 1px solid var(--border);
        padding-right: 0.75rem;
      }
    }
    .layer-number {
      font-family: 'Fira Code', monospace;
      font-size: 0.75rem;
      color: var(--layer-color);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
    }
    .layer-label {
      font-family: 'Orbitron', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--ink);
    }
    .layer-spec {
      font-family: 'Fira Code', monospace;
      font-size: 0.65rem;
      color: var(--text-light);
      margin-top: 0.25rem;
    }
    


    .layer-info {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .layer-title-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .layer-title {
      font-family: 'Orbitron', sans-serif;
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--ink);
    }
    

    
    .layer-funny {
      font-family: 'Lora', Georgia, serif;
      font-size: 0.98rem;
      color: var(--text-muted);
      line-height: 1.6;
      font-style: italic;
    }
    .layer-challenge {
      background: var(--surface-alt);
      border-left: 2px solid var(--accent-red);
      padding: 0.5rem 0.8rem;
      font-size: 0.8rem;
      color: var(--accent-red);
      border-radius: 4px;
      margin-top: 0.25rem;
    }
    
    .layer-chips-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
    }
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    
    /* Interactive Lab Toggle Button */
    .lab-toggle-btn {
      background: transparent;
      border: 1px solid var(--layer-color);
      color: var(--text-muted);
      padding: 0.35rem 0.8rem;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      border-radius: 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: all 0.2s;
    }
    .lab-toggle-btn:hover {
      background: var(--layer-color);
      box-shadow: 0 0 10px var(--layer-color);
      color: #ffffff;
    }

    /* Lab Drawer */
    .lab-drawer {
      max-height: 0;
      overflow: hidden;
      background: var(--surface-alt);
      border-top: 0px solid var(--border);
      transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1), padding 0.3s, border-width 0.1s;
      padding: 0;
      border-width: 0;
    }
    .layer-card.lab-open .lab-drawer {
      border-top: 1px solid var(--border);
      border-width: 1px 0 0 0;
    }

    /* Interactive Widgets styling */
    .lab-widget {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      font-family: 'Space Grotesk', sans-serif;
    }
    .widget-row {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .widget-row label {
      font-family: 'Fira Code', monospace;
      font-size: 0.8rem;
      color: var(--text-light);
      display: flex;
      justify-content: space-between;
    }
    .widget-row label span {
      color: var(--ink);
      font-weight: bold;
    }
    .widget-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
    .widget-stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 0;
      padding: 0.6rem;
      text-align: center;
    }
    .stat-num {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
    }
    .stat-lbl {
      font-size: 0.65rem;
      color: var(--text-light);
      margin-top: 0.15rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .widget-narrative {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.5;
      background: var(--surface-hover);
      padding: 0.6rem 0.8rem;
      border-radius: 0;
      border-left: 2px solid var(--accent);
    }
    
    /* Neon controls */
    .neon-slider {
