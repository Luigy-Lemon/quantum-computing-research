---
import InteractiveBoard from './InteractiveBoard.astro';
import Slider from './Slider.astro';
import StatsGrid from './StatsGrid.astro';
import StatCard from './StatCard.astro';
import NarrativePanel from './NarrativePanel.astro';
---
<InteractiveBoard title="Qudit Dimensionality & Hilbert State-Space" description="Configure qudit dimension (d) and particle count (N) to observe the exponential expansion of the Hilbert state-space, gate depth optimization savings, and the corresponding leakage risk.">
  
  <div class="qd-layout interactive-split-layout" style="--sidebar-width: 440px;">
    <div class="qd-inputs-panel">
      <div class="qd-row">
        <label>Dimensionality (Qudits):</label>
        <div class="qd-btn-group">
          <button class="qd-btn active" data-dim="2">Qubits (d=2)</button>
          <button class="qd-btn" data-dim="3">Qutrits (d=3)</button>
          <button class="qd-btn" data-dim="4">Qudits (d=4)</button>
        </div>
      </div>

      <Slider
        id="qd-particles"
        label="Number of Particles (N):"
        min={1}
        max={8}
        value={4}
        unit="nodes"
        ticks={['1', '2', '3', '4', '5', '6', '7', '8']}
      />

      <StatsGrid columns={3}>
        <StatCard id="qd-states" label="Hilbert Dimension" value="16" color="text-cyan" />
        <StatCard id="qd-saved" label="Gate Depth Saving" value="0%" color="text-green" />
        <StatCard id="qd-leakage" label="Leakage Risk" value="Low" color="text-magenta" />
      </StatsGrid>
    </div>

    <div class="qd-visual-panel">
      <h5 id="qd-visual-title">Transmon Energy Levels & Wavefunction</h5>
      <p class="qd-visual-hint">Left: Energy levels & complex phase clocks. Right: Composite Hilbert space coordinates ($d^N$).</p>
      
      <div class="qd-canvas-container">
        <canvas id="qd-canvas" class="qd-canvas"></canvas>
      </div>
    </div>
  </div>

  <NarrativePanel id="qd-narrative">
    Standard binary qubit architecture. 4 qubits span 16 complex dimensions.
  </NarrativePanel>
</InteractiveBoard>

<style>


  .qd-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .qd-row label {
    font-weight: 600;
    color: var(--text-main);
    font-size: 0.9rem;
  }

  .qd-btn-group {
    display: flex;
    gap: 0.5rem;
  }
  .qd-btn {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 0.5rem;
    font-size: 0.8rem;
    border-radius: var(--radius);
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
  }
  .qd-btn.active, .qd-btn:hover {
    border-color: var(--accent);
    color: #ffffff;
    background: var(--accent);
  }

  .qd-slider-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .qd-slider-group label {
    display: flex;
    justify-content: space-between;
    font-weight: 600;
    color: var(--text-main);
    font-size: 0.9rem;
  }
  .value-display {
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
  }
  .slider-ticks {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: monospace;
    padding: 0 0.2rem;
  }



  .qd-visual-panel {
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 340px;
  }
  .qd-visual-panel h5 {
    margin: 0 0 0.25rem 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .qd-visual-hint {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    max-width: 320px;
    line-height: 1.3;
  }

  .qd-canvas-container {
    width: 100%;
    height: 220px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .qd-canvas {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--surface);
  }
</style>

<script>
  function initQuditDimension() {
    const buttons = document.querySelectorAll('.qd-btn');
    const particlesSlider = document.getElementById('qd-particles') as HTMLInputElement;
    const canvas = document.getElementById('qd-canvas') as HTMLCanvasElement;

    if (buttons.length === 0 || !particlesSlider || !canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let dim = 2;
    let animationFrameId: number;
    let time = 0;

    buttons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        buttons.forEach(b => b.classList.remove('active'));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add('active');
        dim = parseInt(target.getAttribute('data-dim') || '2');
        updateQudit();
      });
    });

    function updateQudit() {
      const particles = parseInt(particlesSlider.value);
      const valDisp = document.getElementById('qd-particles-val');
      if (valDisp) valDisp.textContent = particles.toString();

      const hilbertDim = Math.pow(dim, particles);
      const statesEl = document.getElementById('qd-states');
      if (statesEl) statesEl.textContent = hilbertDim.toLocaleString();

      let savings = 0;
      let leakage = 'Low';
      let leakClass = 'text-green';
      
      if (dim === 3) {
        savings = 42;
        leakage = 'Moderate';
        leakClass = 'text-amber';
      } else if (dim === 4) {
        savings = 62;
        leakage = 'High (Leak)';
        leakClass = 'text-magenta';
      }

      const savedEl = document.getElementById('qd-saved');
      if (savedEl) savedEl.textContent = `${savings}%`;

      const leakEl = document.getElementById('qd-leakage');
      if (leakEl) {
        leakEl.textContent = leakage;
        leakEl.className = `qd-stat-num ${leakClass}`;
      }

      const narrativeEl = document.getElementById('qd-narrative');
      if (narrativeEl) {
        if (dim === 2) {
          narrativeEl.innerHTML = `📘 <strong>Standard Binary Qubits:</strong> A ${particles}-qubit system spans exactly <strong>${hilbertDim} complex dimensions</strong>. Scaling requires direct physical additions to the chip layout, with a linear growth in required physical control channels.`;
        } else if (dim === 3) {
          narrativeEl.innerHTML = `💜 <strong>Ternary Qutrits (d=3):</strong> By unlocking the \\(|2\\rangle\\) state, a ${particles}-particle register achieves the coordinate capacity of <strong>${(particles * 1.58).toFixed(1)} qubits</strong>. This slashes CNOT decomposition depth for multi-controlled arithmetic gates (like Toffoli gates) by <strong>${savings}%</strong>. However, the \\(|2\\rangle\\) state suffers from elevated energy relaxation (\\(\\Gamma_{2\\rightarrow 1} \\approx 2\\Gamma_{1\\rightarrow 0}\\)).`;
        } else {
          narrativeEl.innerHTML = `⚠️ <strong>Ququart Qudits (d=4):</strong> Stacking 4 levels provides a massive <strong>${hilbertDim.toLocaleString()}-dimensional Hilbert space</strong> using only ${particles} physical elements. This saves massive space-time routing overhead on the chip, but introduces severe frequency crowding and spectator state crosstalk that classical pulse synthesizers must resolve.`;
        }
        if (window.MathJax) { window.MathJax.typesetPromise([narrativeEl]); }
      }
    }

    function animate() {
      if (!ctx || !canvas) return;
      time += 0.03;

      const w = canvas.width = canvas.offsetWidth;
      const h = canvas.height = 220;
      ctx.clearRect(0, 0, w, h);

      // Split canvas: Left half is Energy Level Ladder, Right half is Hilbert space grid
      const midX = w / 2;

      // 1. Draw Energy Level Ladder (Left side)
      const ladderLeft = 35;
      const ladderWidth = 100;
      const numLevels = dim;

      const bottomY = h - 40;
      const stepY = 40;

      // Draw levels
      for (let i = 0; i < numLevels; i++) {
        const ly = bottomY - i * stepY;

        // Level line
        ctx.strokeStyle = i === 2 ? '#a855f7' : i === 3 ? '#eab308' : '#3b82f6';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.moveTo(ladderLeft, ly);
        ctx.lineTo(ladderLeft + ladderWidth, ly);
        ctx.stroke();

        // Label
        ctx.font = 'bold 9px monospace';
        ctx.fillStyle = '#64748b';
        ctx.fillText(`|${i}⟩`, ladderLeft - 18, ly + 3);

        // Draw phase clock next to level
        const clockX = ladderLeft + ladderWidth + 20;
        ctx.lineWidth = 1.2;
        ctx.strokeStyle = '#94a3b8';
        ctx.beginPath();
        ctx.arc(clockX, ly, 10, 0, Math.PI * 2);
        ctx.stroke();

        // Animate clock needle representing phase rotation
        const phaseSpeed = (i + 1) * 0.5;
        const needleX = clockX + 8 * Math.cos(time * phaseSpeed);
        const needleY = ly + 8 * Math.sin(time * phaseSpeed);
        ctx.strokeStyle = i === 2 ? '#a855f7' : i === 3 ? '#eab308' : '#3b82f6';
        ctx.beginPath();
        ctx.moveTo(clockX, ly);
        ctx.lineTo(needleX, needleY);
        ctx.stroke();

        // Draw rabi transitions between levels (wavy arrows)
        if (i < numLevels - 1) {
          const arrowY = ly - stepY / 2;
          ctx.strokeStyle = 'rgba(236, 72, 153, 0.4)';
          ctx.lineWidth = 1;
          ctx.beginPath();
          // Sine wave representation
          for (let tx = ladderLeft + 10; tx <= ladderLeft + ladderWidth - 10; tx++) {
            const ty = arrowY + 4 * Math.sin((tx - ladderLeft) * 0.2 + time * 5);
            ctx.lineTo(tx, ty);
          }
          ctx.stroke();

          // Write transition frequency
          ctx.font = '7px monospace';
          ctx.fillStyle = '#db2777';
          ctx.textAlign = 'center';
          const transitionLabel = i === 0 ? 'f_01 ≈ 5.0 GHz' : i === 1 ? 'f_12 ≈ 4.7 GHz (α ≈ -300MHz)' : 'f_23 ≈ 4.4 GHz';
          ctx.fillText(transitionLabel, ladderLeft + ladderWidth / 2, arrowY - 6);
        }
      }

      // 2. Draw Hilbert Space Grid (Right side)
      const particles = parseInt(particlesSlider.value);
      const totalStates = Math.pow(dim, particles);

      const gridCenterX = midX + (w - midX) / 2;
      const gridCenterY = h / 2;

      ctx.strokeStyle = 'rgba(148, 163, 184, 0.15)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(midX, 15); ctx.lineTo(midX, h - 15);
      ctx.stroke();

      if (totalStates <= 64) {
        const cols = Math.min(totalStates, 8);
        const rows = Math.ceil(totalStates / cols);
        const size = 12;
        const gap = 6;
        const startX = gridCenterX - (cols * (size + gap) - gap) / 2;
        const startY = gridCenterY - (rows * (size + gap) - gap) / 2;

        for (let i = 0; i < totalStates; i++) {
          const r = Math.floor(i / cols);
          const c = i % cols;
          const x = startX + c * (size + gap) + size / 2;
          const y = startY + r * (size + gap) + size / 2;

          ctx.beginPath();
          ctx.arc(x, y, size / 2 - 1.5, 0, Math.PI * 2);
          ctx.fillStyle = dim === 2 ? 'rgba(59, 130, 246, 0.45)' : dim === 3 ? 'rgba(168, 85, 247, 0.45)' : 'rgba(234, 179, 8, 0.45)';
          ctx.strokeStyle = dim === 2 ? '#3b82f6' : dim === 3 ? '#a855f7' : '#eab308';
          ctx.lineWidth = 1;
          ctx.fill();
          ctx.stroke();
        }
      } else {
        ctx.font = '9px monospace';
        ctx.fillStyle = 'var(--text-muted)';
        ctx.textAlign = 'center';
        ctx.fillText(`State space too complex`, gridCenterX, gridCenterY - 15);
        ctx.fillText(`(${totalStates.toLocaleString()} dimensions)`, gridCenterX, gridCenterY - 3);

        // Draw cloud of floating orbital dots
        const dots = 80;
        for (let i = 0; i < dots; i++) {
          const angle = (i * (360 / dots)) * Math.PI / 180 + time * 0.1;
          const radius = 25 + Math.sin(time + i) * 12 + (i % 3) * 15;
          const x = gridCenterX + radius * Math.cos(angle);
          const y = gridCenterY + 15 + radius * Math.sin(angle) * 0.6;

          ctx.beginPath();
          ctx.arc(x, y, 1.5, 0, Math.PI * 2);
          ctx.fillStyle = dim === 3 ? 'rgba(168, 85, 247, 0.7)' : 'rgba(234, 179, 8, 0.7)';
          ctx.fill();
        }
      }

      animationFrameId = requestAnimationFrame(animate);
    }

    particlesSlider.addEventListener('input', updateQudit);
    updateQudit();
    animate();

    return () => {
      if (animationFrameId) cancelAnimationFrame(animationFrameId);
    };
  }

  let cleanup: (() => void) | undefined;
  function run() {
    if (cleanup) cleanup();
    cleanup = initQuditDimension();
  }

  run();
  document.addEventListener('astro:page-load', run);
</script>
