---
import InteractiveBoard from './InteractiveBoard.astro';

interface TimelineItem {
  year: string;
  title: string;
  description: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<InteractiveBoard className="timeline-board" title="Research & Technology Milestones" description="Explore the historical progression and key breakthroughs in this domain.">
  <div class="timeline-interactive-container">
    <div class="timeline-nav">
      {items.map((item, index) => (
        <button class={`timeline-tab ${index === 0 ? 'active' : ''}`} data-index={index}>
          {item.year}
        </button>
      ))}
    </div>
    
    <div class="timeline-content-area">
      {items.map((item, index) => (
        <div class={`timeline-panel ${index === 0 ? 'active' : ''}`} id={`timeline-panel-${index}`}>
          <h4 class="timeline-title">{item.title}</h4>
          <p class="timeline-description" set:html={item.description}></p>
        </div>
      ))}
    </div>
  </div>
</InteractiveBoard>

<style>
  .timeline-interactive-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .timeline-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 2px solid var(--border-light);
    padding-bottom: 0.5rem;
  }
  
  .timeline-tab {
    background: transparent !important;
    border: none !important;
    padding: 0.5rem 1rem;
    font-family: 'Source Code Pro', 'Fira Code', monospace;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-muted) !important;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s ease;
  }
  
  .timeline-tab:hover {
    background: var(--surface-alt) !important;
    color: var(--text-main) !important;
  }
  
  .timeline-tab.active {
    background: rgba(255, 176, 0, 0.1) !important;
    color: var(--accent) !important;
    font-weight: 700;
    border: 1px solid var(--accent) !important;
  }
  
  .timeline-content-area {
    background: var(--surface);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 1.5rem;
    min-height: 120px;
    box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
  }
  
  .timeline-panel {
    display: none;
    animation: fadeIn 0.3s ease;
  }
  
  .timeline-panel.active {
    display: block;
  }
  
  .timeline-title {
    margin: 0 0 1rem 0;
    font-size: 1.25rem;
    color: var(--text-main);
    font-weight: 700;
  }
  
  .timeline-description {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 1rem;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const timelineContainers = document.querySelectorAll('.timeline-interactive-container');
  
  timelineContainers.forEach(container => {
    const tabs = container.querySelectorAll('.timeline-tab');
    const panels = container.querySelectorAll('.timeline-panel');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));

        tab.classList.add('active');
        const index = tab.getAttribute('data-index');
        const activePanel = container.querySelector(`#timeline-panel-${index}`);
        if (activePanel) {
          activePanel.classList.add('active');
        }
      });
    });
  });
</script>
