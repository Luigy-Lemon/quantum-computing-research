---
import InteractiveBoard from './InteractiveBoard.astro';
---

<InteractiveBoard title="DRAG Pulse Shaping" description="Visualize Microwave Pulse shaping (I and Q envelopes) over time.">
  <div class="drag-container" data-drag-visualizer>
    <div class="controls">
      <button class="pulse-btn active" data-type="gaussian" data-explanation="A standard Gaussian envelope driving the qubit at the transition frequency. Because of frequency crowding, its spectral width leaks energy into the adjacent |1⟩ -> |2⟩ transition, causing state leakage.">Standard Gaussian</button>
      <button class="pulse-btn" data-type="drag" data-explanation="By adding a phase-shifted derivative envelope on the quadrature channel, DRAG dynamically shifts the qubit's frequency during the drive. This Stark-shifting causes the leakage pathway to destructively interfere with itself, canceling leakage to |2⟩.">DRAG Pulse</button>
      <button class="pulse-btn" data-type="grape" data-explanation="Gradient Ascent Pulse Engineering slices the pulse into 1ns pixels and optimizes their amplitudes using gradient ascent. The resulting irregular waveform maximizes gate speed while actively canceling out leakage to higher states via multi-frequency interference.">GRAPE</button>
    </div>
    
    <div class="canvas-wrapper">
      <canvas></canvas>
      <div class="legend">
        <span class="legend-item"><span class="color-box i-env"></span> I Envelope</span>
        <span class="legend-item"><span class="color-box q-env"></span> Q Envelope</span>
        <span class="legend-item"><span class="color-box leakage"></span> Leakage to |2⟩</span>
      </div>
    </div>
  </div>

  <style>
    .drag-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      width: 100%;
      font-family: system-ui, -apple-system, sans-serif;
    }
    
    .controls {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    
    .pulse-btn {
      background: var(--border-light);
      border: 1px solid var(--border-light);
      color: #94a3b8;
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      cursor: pointer;
      font-weight: 500;
      transition: all 0.2s ease;
      font-size: 0.9rem;
      letter-spacing: 0.025em;
    }
    
    .pulse-btn:hover {
      background: var(--border-light);
      border-color: var(--border-light);
      color: #e2e8f0;
      transform: translateY(-1px);
    }
    
    .pulse-btn.active {
      background: rgba(59, 130, 246, 0.15);
      border-color: rgba(59, 130, 246, 0.5);
      color: #60a5fa;
      box-shadow: 0 0 15px rgba(59, 130, 246, 0.2);
    }
    
    .canvas-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      background: var(--surface);
      border-radius: 1rem;
      border: 1px solid var(--border-light);
      overflow: hidden;
      box-shadow: none;
    }
    
    canvas {
      width: 100%;
      height: 100%;
      display: block;
    }
    
    .legend {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      background: rgba(2, 6, 23, 0.7);
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      border: 1px solid var(--border-light);
      backdrop-filter: blur(8px);
    }
    
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: #cbd5e1;
      font-size: 0.85rem;
      font-weight: 500;
    }
    
    .color-box {
      width: 10px;
      height: 10px;
      border-radius: 2px;
    }
    
    .i-env { background: #3b82f6; box-shadow: 0 0 8px #3b82f6; }
    .q-env { background: #ef4444; box-shadow: 0 0 8px #ef4444; }
    .leakage { background: #10b981; box-shadow: 0 0 8px #10b981; }
  </style>

  <script>
    class PulseVisualizer {
      constructor(container) {
        this.container = container;
        this.canvas = container.querySelector('canvas');
        if (!this.canvas) return;
        
        this.ctx = this.canvas.getContext('2d');
        this.type = 'gaussian';
        this.time = 0;
        
        this.resize = this.resize.bind(this);
        this.animate = this.animate.bind(this);
        
        window.addEventListener('resize', this.resize);
        this.resize();
        
        this.setupControls();
        this.animate();
      }
      
      setupControls() {
        const btns = this.container.querySelectorAll('.pulse-btn');
        btns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            btns.forEach(b => b.classList.remove('active'));
            const target = e.currentTarget as HTMLElement;
            target.classList.add('active');
            this.type = target.dataset.type || 'gaussian';
            this.time = 0; // reset animation for satisfying transition
          });
        });
      }
      
      resize() {
        const rect = this.canvas.parentElement?.getBoundingClientRect();
        if (!rect) return;
        this.canvas.width = rect.width * window.devicePixelRatio;
        this.canvas.height = rect.height * window.devicePixelRatio;
        this.ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
        this.width = rect.width;
        this.height = rect.height;
      }
      
      animate() {
        this.time += 0.02;
        this.draw();
        requestAnimationFrame(this.animate);
      }
      
      draw() {
        const { ctx, width, height } = this;
        ctx.clearRect(0, 0, width, height);
        
        // Draw grid
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.03)';
        ctx.lineWidth = 1;
        
        const gridCells = 12;
        for (let i = 0; i <= gridCells; i++) {
          ctx.beginPath();
          ctx.moveTo(0, height * (i / gridCells));
          ctx.lineTo(width, height * (i / gridCells));
          ctx.stroke();
          
          ctx.beginPath();
          ctx.moveTo(width * (i / gridCells), 0);
          ctx.lineTo(width * (i / gridCells), height);
          ctx.stroke();
        }
        
        // Draw center horizontal line
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.15)';
        ctx.beginPath();
        ctx.moveTo(0, height / 2);
        ctx.lineTo(width, height / 2);
        ctx.stroke();
        
        const points = 250;
        const iPath: {x: number, y: number}[] = [];
        const qPath: {x: number, y: number}[] = [];
        const leakPath: {x: number, y: number}[] = [];
        
        // Smooth ease-out animation curve for pulse intro
        const animT = Math.min(1, this.time / 1.5);
        const animatedProgress = 1 - Math.pow(1 - animT, 3);
        
        for (let i = 0; i <= points; i++) {
          const t = i / points;
          const x = t * width;
          
          // normalized time centered around 0
          const nt = (t - 0.5) * 6; // from -3 to 3
          
          let iVal = 0;
          let qVal = 0;
          let leakVal = 0;
          
          if (this.type === 'gaussian') {
            iVal = Math.exp(-nt * nt / 2);
            qVal = 0;
            // High leakage for standard gaussian
            leakVal = 0.45 * Math.exp(-nt * nt / 1.5) * Math.abs(Math.sin(this.time * 4 + nt * 3));
          } else if (this.type === 'drag') {
            iVal = Math.exp(-nt * nt / 2);
            // Q is derivative of I
            qVal = -nt * Math.exp(-nt * nt / 2) * 0.5;
            // Leakage drastically suppressed
            leakVal = 0.03 * Math.exp(-nt * nt / 2) * Math.abs(Math.sin(this.time * 6 + nt * 2));
          } else if (this.type === 'grape') {
            const segments = 30;
            const segmentIdx = Math.floor(t * segments);
            
            // simple pseudo-random hash for deterministic "noise"
            const hash = (n: number) => {
              let h = Math.imul(1540483477, n);
              h ^= h >>> 24;
              h = Math.imul(1540483477, h);
              return ((h >>> 0) / 4294967295) * 2 - 1;
            };
            
            const env = Math.exp(-nt * nt / 2.5);
            
            iVal = env * (0.7 + hash(segmentIdx) * 0.4);
            qVal = env * hash(segmentIdx + 100) * 0.6;
            leakVal = env * Math.abs(hash(segmentIdx + 200)) * 0.15;
          }
          
          iVal *= animatedProgress;
          qVal *= animatedProgress;
          leakVal *= animatedProgress;
          
          iPath.push({x, y: height / 2 - iVal * (height * 0.35)});
          qPath.push({x, y: height / 2 - qVal * (height * 0.35)});
          leakPath.push({x, y: height * 0.95 - leakVal * (height * 0.25)});
        }
        
        this.drawPath(iPath, '#3b82f6', 3);
        
        if (this.type !== 'gaussian' || this.type === 'grape') {
           this.drawPath(qPath, '#ef4444', 3);
        }
        
        this.drawPath(leakPath, '#10b981', 2, true);
      }
      
      drawPath(points: {x: number, y: number}[], color: string, strokeWidth: number, fill = false) {
        if (points.length === 0) return;
        
        this.ctx.strokeStyle = color;
        this.ctx.lineWidth = strokeWidth;
        this.ctx.lineJoin = 'round';
        this.ctx.lineCap = 'round';
        
        this.ctx.beginPath();
        this.ctx.moveTo(points[0].x, points[0].y);
        
        if (this.type === 'grape') {
          // Pixelated / stepped rendering for optimal control
          for (let i = 1; i < points.length; i++) {
            this.ctx.lineTo(points[i].x, points[i-1].y);
            this.ctx.lineTo(points[i].x, points[i].y);
          }
        } else {
          // Smooth rendering
          for (let i = 1; i < points.length; i++) {
            this.ctx.lineTo(points[i].x, points[i].y);
          }
        }
        
        if (fill) {
          // Close path to the bottom for fill
          this.ctx.lineTo(points[points.length - 1].x, this.height);
          this.ctx.lineTo(points[0].x, this.height);
          
          const r = parseInt(color.slice(1, 3), 16);
          const g = parseInt(color.slice(3, 5), 16);
          const b = parseInt(color.slice(5, 7), 16);
              
          this.ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.15)`;
          this.ctx.fill();
        } else {
          this.ctx.stroke();
        }
        
        // Add subtle glow effect
        this.ctx.shadowColor = color;
        this.ctx.shadowBlur = 10;
        this.ctx.stroke();
        this.ctx.shadowBlur = 0; // reset
      }
    }

    const init = () => {
      document.querySelectorAll('[data-drag-visualizer]').forEach(el => {
        if (!(el as any).dataset.initialized) {
          new PulseVisualizer(el);
          (el as any).dataset.initialized = 'true';
        }
      });
    };

    init();
    document.addEventListener('astro:page-load', init);
  </script>
</InteractiveBoard>
