---
export interface Props {
  title: string;
  meta: string;
  description?: string;
  theme?: string;
}

const { title, meta, description, theme = "cyan" } = Astro.props;
---
<header class="page-header" style={`--theme-color: var(--accent-${theme});`}>
  <div class="meta-tag">{meta}</div>
  <h1 class="page-title">{title}</h1>
  {description && <p class="page-description">{description}</p>}
</header>
<style>
  .page-header {
    margin-bottom: 4rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
  }
  .meta-tag {
    font-family: 'Fira Code', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--theme-color);
    margin-bottom: 1rem;
    display: inline-block;
    padding: 0.2rem 0.6rem;
    background: color-mix(in srgb, var(--theme-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--theme-color) 30%, transparent);
    border-radius: var(--radius);
  }
  .page-title {
    font-size: 3rem;
    font-family: 'Orbitron', sans-serif;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--text-main);
    line-height: 1.2;
  }
  .page-description {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-secondary);
    font-family: 'Lora', Georgia, serif;
    max-width: 800px;
  }
</style>
