---
import NarrativePanel from './NarrativePanel.astro';

interface Props {
  defaultText: string;
}

const { defaultText } = Astro.props;
---

<NarrativePanel class="hover-info-panel">
  <div class="info-content">{defaultText}</div>
</NarrativePanel>

<style>
  .hover-info-panel {
    min-height: 4.5rem;
    display: flex;
    align-items: center;
  }
  .info-content {
    font-size: 0.95rem;
    color: var(--text-main);
    width: 100%;
  }
</style>

<script>
  document.querySelectorAll('.hover-info-panel').forEach(panel => {
    const content = panel.querySelector('.info-content');
    if (!content) return;
    const defaultText = content.textContent ?? '';
    panel.closest('.interactive-board-container')?.querySelectorAll('.hoverable').forEach(el => {
      el.addEventListener('mouseenter', () => {
        content.textContent = el.getAttribute('data-info') || '';
        (content as HTMLElement).style.color = 'var(--accent-dark)';
      });
      el.addEventListener('mouseleave', () => {
        content.textContent = defaultText;
        (content as HTMLElement).style.color = 'var(--text-main)';
      });
    });
  });
</script>
