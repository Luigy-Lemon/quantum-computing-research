---
import InteractiveBoard from './InteractiveBoard.astro';
import Slider from './Slider.astro';
import StatsGrid from './StatsGrid.astro';
import StatCard from './StatCard.astro';
import NarrativePanel from './NarrativePanel.astro';
---
<InteractiveBoard id="lab" title="QND Measurement Fidelity & HEMT Noise" description="Optimize measurement integration time and HEMT amplifier noise temperature to maximize readout state-discrimination fidelity and prevent T1 relaxation smearing.">
  
  <div class="rf-layout interactive-split-layout" style="--sidebar-width: 360px;">
    <div class="rf-inputs-panel">
      <Slider
        id="rf-time"
        label="Integration Measurement Time:"
        min={40}
        max={600}
        step={10}
        value={180}
        unit="ns"
        ticks={['40 ns', '150 ns', '300 ns', '450 ns', '600 ns']}
      />

      <Slider
        id="rf-noise"
        label="HEMT Amplifier Noise Temp:"
        min={0.1}
        max={1.5}
        step={0.05}
        value={0.30}
        unit="K"
        ticks={['0.1 K', '0.5 K', '1.0 K', '1.5 K']}
      />

      <StatsGrid columns={3}>
        <StatCard id="rf-fidelity" label="Readout Fidelity" value="99.1%" color="text-cyan" />
        <StatCard id="rf-decay" label="T1 Decay Error" value="0.9%" color="text-magenta" />
        <StatCard id="rf-overlap" label="Thermal Overlap" value="0.0%" color="text-green" />
      </StatsGrid>
    </div>

    <div class="rf-visual-panel">
      <h5>IQ State Space & RF Cavity Oscilloscope</h5>
      <p class="rf-visual-hint">Left: Demodulated IQ voltage plane blobs. Right: Real-time cavity trace V(t) with HEMT noise and T1 decay phase jump.</p>
      
      <div class="rf-canvas-container">
        <canvas id="rf-canvas" class="rf-canvas"></canvas>
      </div>
    </div>
  </div>

  <NarrativePanel id="rf-narrative">
    Microwave readouts return I/Q signals. Shorter integration fails to separate blobs against HEMT noise (left overlaps). Longer integration risks the |1⟩ decaying to |0⟩ mid-measurement, smearing red into blue.
  </NarrativePanel>
</InteractiveBoard>

<style>



</style>

<script>
  function initReadoutFidelity() {
    const timeSlider = document.getElementById('rf-time') as HTMLInputElement;
    const noiseSlider = document.getElementById('rf-noise') as HTMLInputElement;
    const canvas = document.getElementById('rf-canvas') as HTMLCanvasElement;

    if (!canvas || !timeSlider || !noiseSlider) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animTime = 0;
    let animationFrameId: number;

    function renderLoop() {
      animTime += 0.05;
      draw();
      animationFrameId = requestAnimationFrame(renderLoop);
    }

    function draw() {
      const time = parseInt(timeSlider.value);
      const noise = parseFloat(noiseSlider.value);

      const timeVal = document.getElementById('rf-time-val');
      const noiseVal = document.getElementById('rf-noise-val');
      if (timeVal) timeVal.textContent = time.toString();
      if (noiseVal) noiseVal.textContent = noise.toFixed(2);

      const separation = 2.4 * Math.sqrt(time / 180);
      const stdDev = 14 * noise;

      // Realistic T1 relaxation calculation
      const t1 = 30000; // 30 μs = 30000 ns
      const decayProb = 1 - Math.exp(-time / t1);
      const decayEl = document.getElementById('rf-decay');
      if (decayEl) decayEl.textContent = `${(decayProb * 100).toFixed(1)}%`;

      const w = canvas.width = canvas.offsetWidth;
      const h = canvas.height = 200;
      ctx.clearRect(0, 0, w, h);

      // Split canvas horizontally
      const midX = w * 0.45;

      // --- Left: IQ plane plot ---
      const cx = midX / 2;
      const cy = h / 2;

      // Draw grid axes
      ctx.strokeStyle = '#f1f5f9';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(10, cy); ctx.lineTo(midX - 10, cy);
      ctx.moveTo(cx, 10); ctx.lineTo(cx, h - 10);
      ctx.stroke();

      ctx.fillStyle = '#94a3b8';
      ctx.font = '7px monospace';
      ctx.fillText('+I', midX - 22, cy - 4);
      ctx.fillText('+Q', cx + 4, 15);

      function randNormal(mean: number, std: number) {
        let u = 0, v = 0;
        while(u === 0) u = Math.random();
        while(v === 0) v = Math.random();
        let num = Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
        return num * std + mean;
      }

      const numPoints = 80;
      let misclassified = 0;
      let thermalOverlaps = 0;

      // Draw |0> state distribution (Cyan)
      ctx.fillStyle = 'rgba(6, 182, 212, 0.65)';
      const mean0 = cx - separation * 8;
      for (let i = 0; i < numPoints; i++) {
        const px = randNormal(mean0, stdDev);
        const py = randNormal(cy, stdDev);
        ctx.beginPath();
        ctx.arc(px, py, 2.2, 0, Math.PI * 2);
        ctx.fill();

        if (px > cx) misclassified++;
      }

      // Draw |1> state distribution (Magenta / Comet tail decay)
      const mean1 = cx + separation * 8;
      for (let i = 0; i < numPoints; i++) {
        const decayed = Math.random() < decayProb;
        let px, py;

        if (decayed) {
          const fraction = Math.random();
          const intermediateMean = mean1 - fraction * (mean1 - mean0);
          px = randNormal(intermediateMean, stdDev);
          py = randNormal(cy, stdDev);
          ctx.fillStyle = 'rgba(244, 63, 94, 0.45)'; // Smear red-ish
        } else {
          px = randNormal(mean1, stdDev);
          py = randNormal(cy, stdDev);
          ctx.fillStyle = 'rgba(217, 70, 239, 0.65)'; // Magenta |1>
        }

        ctx.beginPath();
        ctx.arc(px, py, 2.2, 0, Math.PI * 2);
        ctx.fill();

        if (px < cx) {
          misclassified++;
          if (decayed) thermalOverlaps++;
        }
      }

      const totalFidelity = 100 - (misclassified / (numPoints * 2)) * 100;
      const fidEl = document.getElementById('rf-fidelity');
      if (fidEl) {
        fidEl.textContent = `${totalFidelity.toFixed(1)}%`;
        if (totalFidelity > 99.0) { fidEl.className = 'rf-stat-num text-green'; }
        else if (totalFidelity > 95.0) { fidEl.className = 'rf-stat-num text-cyan'; }
        else { fidEl.className = 'rf-stat-num text-magenta'; }
      }

      const overlapPct = (thermalOverlaps / numPoints) * 100;
      const overlapEl = document.getElementById('rf-overlap');
      if (overlapEl) overlapEl.textContent = `${overlapPct.toFixed(1)}%`;

      // Draw SVM Decision Boundary (dashed line)
      ctx.strokeStyle = '#ef4444';
      ctx.setLineDash([3, 3]);
      ctx.lineWidth = 1.2;
      ctx.beginPath();
      ctx.moveTo(cx, 15);
      ctx.lineTo(cx, h - 15);
      ctx.stroke();
      ctx.setLineDash([]);

      // --- Right: Raw Oscilloscope Cavity Trace ---
      const oscLeft = midX + 15;
      const oscWidth = w - oscLeft - 15;
      const oscCenterY = h / 2;
      const oscHeight = h - 60;

      // Draw boundary partition
      ctx.strokeStyle = 'rgba(148, 163, 184, 0.15)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(midX, 15); ctx.lineTo(midX, h - 15);
      ctx.stroke();

      // Oscilloscope background grid
      ctx.fillStyle = '#0f172a'; // Dark retro CRT look
      ctx.fillRect(oscLeft, oscCenterY - oscHeight / 2, oscWidth, oscHeight);

      ctx.strokeStyle = 'rgba(34, 197, 94, 0.1)'; // CRT grid lines
      ctx.lineWidth = 0.5;
      const gridSpacing = 20;
      for (let gx = oscLeft; gx < oscLeft + oscWidth; gx += gridSpacing) {
        ctx.beginPath(); ctx.moveTo(gx, oscCenterY - oscHeight / 2); ctx.lineTo(gx, oscCenterY + oscHeight / 2); ctx.stroke();
      }
      for (let gy = oscCenterY - oscHeight / 2; gy < oscCenterY + oscHeight / 2; gy += gridSpacing) {
        ctx.beginPath(); ctx.moveTo(oscLeft, gy); ctx.lineTo(oscLeft + oscWidth, gy); ctx.stroke();
      }

      // Draw signal trace
      ctx.strokeStyle = '#22c55e'; // CRT Green
      ctx.lineWidth = 1.5;
      ctx.beginPath();

      // Determine if a decay occurs mid-measurement trace
      const hasDecay = decayProb > 0.35 && (Math.sin(animTime * 0.1) > 0.1);
      const decayThresholdIndex = Math.round(oscWidth * 0.55); // decays 55% of the way

      for (let i = 0; i < oscWidth; i++) {
        const xPos = oscLeft + i;
        const phaseVal = (hasDecay && i > decayThresholdIndex) ? 0 : Math.PI / 2;
        const frequency = 0.12;

        const cleanSignal = Math.sin(i * frequency + animTime + phaseVal);
        const noiseVal = (Math.random() - 0.5) * noise * 0.8;
        const signalVal = (cleanSignal * 18 * Math.min(1, time / 100)) + noiseVal * 12;

        const yPos = oscCenterY + Math.max(-oscHeight/2 + 2, Math.min(oscHeight/2 - 2, signalVal));
        if (i === 0) {
          ctx.moveTo(xPos, yPos);
        } else {
          ctx.lineTo(xPos, yPos);
        }
      }
      ctx.stroke();

      // Labels on scope
      ctx.font = '8px monospace';
      ctx.fillStyle = '#22c55e';
      ctx.textAlign = 'right';
      ctx.fillText('CH1 (Cavity Out)', oscLeft + oscWidth - 5, oscCenterY - oscHeight / 2 + 12);
      if (hasDecay) {
        ctx.fillStyle = '#ef4444';
        ctx.fillText('T1 DECAY DETECTED', oscLeft + oscWidth - 5, oscCenterY + oscHeight / 2 - 8);
      }
    }

    timeSlider.addEventListener('input', draw);
    noiseSlider.addEventListener('input', draw);
    
    renderLoop();

    return () => {
      cancelAnimationFrame(animationFrameId);
    };
  }

  // Run on load
  let cleanup: (() => void) | undefined;
  function run() {
    if (cleanup) cleanup();
    cleanup = initReadoutFidelity();
  }

  run();
  document.addEventListener('astro:page-load', run);
</script>
