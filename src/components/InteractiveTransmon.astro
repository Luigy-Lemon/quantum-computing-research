---
import InteractiveBoard from './InteractiveBoard.astro';
import HoverInfoPanel from './HoverInfoPanel.astro';
---
<InteractiveBoard className="transmon-container" title="Cross-Shaped Transmon Qubit Schematic" description="Hover over the components to understand the physical architecture of a superconducting transmon.">
  
  <div class="transmon-graphic">
    <svg viewBox="0 0 400 300" width="100%" height="100%" class="transmon-svg">
      <defs>
        <filter id="glow-gold">
          <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
        <pattern id="substrate-pattern" width="20" height="20" patternUnits="userSpaceOnUse">
          <path d="M 20 0 L 0 20 M 0 0 L 20 20" fill="none" stroke="var(--border-light)" stroke-width="0.5" opacity="0.3" />
        </pattern>
      </defs>

      <!-- Substrate -->
      <rect x="10" y="10" width="380" height="280" rx="8" fill="url(#substrate-pattern)" stroke="var(--border)" stroke-width="2" />
      <text x="380" y="280" class="sub-label" text-anchor="end">Ultra-pure Silicon Substrate</text>

      <!-- Shunt Capacitor (Cross shape) -->
      <g class="comp-group hoverable" data-info="Shunt Capacitor (Cross): Massive niobium pads provide large capacitance (~100 fF) to flatten the charge dispersion and protect against charge noise.">
        <!-- Top Pad -->
        <path d="M 170 50 L 230 50 L 230 140 L 170 140 Z" fill="var(--surface-alt)" stroke="var(--accent)" stroke-width="3" class="niobium" />
        <!-- Bottom Pad -->
        <path d="M 170 160 L 230 160 L 230 250 L 170 250 Z" fill="var(--surface-alt)" stroke="var(--accent)" stroke-width="3" class="niobium" />
      </g>

      <!-- Josephson Junctions (SQUID loop) -->
      <g class="comp-group hoverable" data-info="Josephson Junctions (SQUID loop): Two ultra-thin Al/AlOx/Al junctions in a loop form a tunable non-linear inductor, yielding the anharmonic energy levels.">
        <!-- Loop connections -->
        <line x1="190" y1="140" x2="190" y2="160" stroke="var(--accent-orange)" stroke-width="2" />
        <line x1="210" y1="140" x2="210" y2="160" stroke="var(--accent-orange)" stroke-width="2" />
        
        <!-- Junction X marks -->
        <g stroke="var(--accent-orange)" stroke-width="2.5" class="junction">
          <line x1="185" y1="145" x2="195" y2="155" />
          <line x1="195" y1="145" x2="185" y2="155" />
        </g>
        <g stroke="var(--accent-orange)" stroke-width="2.5" class="junction">
          <line x1="205" y1="145" x2="215" y2="155" />
          <line x1="215" y1="145" x2="205" y2="155" />
        </g>
        <!-- Flux bias line representation -->
        <path d="M 235 150 Q 250 150 250 170 L 250 250" fill="none" stroke="var(--accent-purple)" stroke-width="2" stroke-dasharray="4 4" />
      </g>

      <!-- Readout Resonator Coupling -->
      <g class="comp-group hoverable" data-info="Readout Resonator Coupling: Coplanar waveguide trace that capacitively couples the transmon state to the microwave readout cavity.">
        <path d="M 50 80 L 140 80 L 140 100 L 160 100" fill="none" stroke="var(--accent-cyan)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" class="readout-trace" />
        <path d="M 140 80 L 140 60 L 160 60" fill="none" stroke="var(--accent-cyan)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" class="readout-trace" />
      </g>

      <!-- XY Drive Line Coupling -->
      <g class="comp-group hoverable" data-info="XY Microwave Drive: Delivers microwave pulses (~5 GHz) to drive transitions between |0⟩ and |1⟩ states (X and Y rotations).">
        <path d="M 50 220 L 140 220 L 140 200 L 160 200" fill="none" stroke="var(--accent-pink)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="drive-trace" />
      </g>
    </svg>
  </div>
  
  <HoverInfoPanel defaultText="Hover over a component to reveal its function in the transmon architecture." />
</InteractiveBoard>

<style>
  .transmon-graphic {
    background: var(--surface-alt);
    border-radius: 6px;
    padding: 1rem;
  }
  .sub-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    fill: var(--text-muted);
  }
  .niobium {
    transition: all 0.2s ease;
  }
  .junction {
    transition: all 0.2s ease;
  }
  .readout-trace, .drive-trace {
    transition: all 0.2s ease;
  }
  
  .hoverable {
    cursor: pointer;
  }
  .hoverable:hover .niobium {
    fill: rgba(37, 99, 235, 0.2);
    stroke-width: 4;
    filter: url(#glow-gold);
  }
  .hoverable:hover .junction {
    stroke-width: 4;
    filter: url(#glow-gold);
  }
  .hoverable:hover .readout-trace {
    stroke-width: 8;
    filter: url(#glow-gold);
  }
  .hoverable:hover .drive-trace {
    stroke-width: 6;
    filter: url(#glow-gold);
  }
</style>
