---
import InteractiveBoard from './InteractiveBoard.astro';
import HoverInfoPanel from './HoverInfoPanel.astro';
---
<InteractiveBoard className="transmon-container" title="Cross-Shaped Transmon Qubit Schematic" description="Hover over the wireframe components to visualize signal propagation and quantum physics mechanisms.">
  
  <div class="transmon-graphic">
    <svg viewBox="0 0 400 300" width="100%" height="100%" class="transmon-svg">
      <defs>
        <filter id="amber-glow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="4" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
        
        <!-- Abstract Substrate grid -->
        <pattern id="grid-pattern" width="20" height="20" patternUnits="userSpaceOnUse">
          <path d="M 20 0 L 0 0 0 20" fill="none" stroke="var(--border-light)" stroke-width="0.5" opacity="0.3" />
        </pattern>
        
        <!-- Sine wave pattern for XY drive animation -->
        <pattern id="sine-wave" x="0" y="0" width="40" height="10" patternUnits="userSpaceOnUse">
          <path d="M 0 5 Q 10 0, 20 5 T 40 5" fill="none" stroke="var(--accent)" stroke-width="1.5" />
        </pattern>
      </defs>

      <!-- Substrate -->
      <rect x="10" y="10" width="380" height="280" rx="4" fill="var(--surface-alt)" stroke="var(--border)" stroke-width="1" />
      <rect x="10" y="10" width="380" height="280" rx="4" fill="url(#grid-pattern)" />
      
      <!-- Substrate Label -->
      <text x="380" y="280" class="hud-label" text-anchor="end">Ultra-pure Substrate (Dielectric)</text>

      <!-- Readout Resonator Coupling -->
      <g class="comp-group hoverable" id="readout-group" data-info="Readout Resonator: A coplanar waveguide cavity. When driven at its resonant frequency, a standing microwave photon wave forms, shifting its phase based on the transmon's state.">
        <!-- Static Wireframe -->
        <path d="M 50 80 L 140 80 L 140 100 L 160 100" fill="none" stroke="var(--text-muted)" stroke-width="2" class="static-trace" />
        <path d="M 140 80 L 140 60 L 160 60" fill="none" stroke="var(--text-muted)" stroke-width="2" class="static-trace" />
        <!-- Animated Standing Wave Overlay (Hidden by default) -->
        <path d="M 50 80 L 140 80 L 140 100 L 160 100" fill="none" stroke="var(--accent)" stroke-width="2" class="anim-trace readout-anim standing-wave" opacity="0" filter="url(#amber-glow)" />
        <path d="M 140 80 L 140 60 L 160 60" fill="none" stroke="var(--accent)" stroke-width="2" class="anim-trace readout-anim standing-wave" opacity="0" filter="url(#amber-glow)" />
      </g>

      <!-- XY Drive Line Coupling -->
      <g class="comp-group hoverable" id="drive-group" data-info="XY Microwave Drive: Delivers shaped microwave pulses (~5 GHz) to drive coherent Rabi oscillations between |0⟩ and |1⟩ states.">
        <!-- Static Wireframe -->
        <path d="M 50 220 L 140 220 L 140 200 L 160 200" fill="none" stroke="var(--text-muted)" stroke-width="2" class="static-trace" />
        <!-- Animated Sine Wave Overlay (Hidden by default) -->
        <path d="M 50 220 L 140 220 L 140 200 L 160 200" fill="none" stroke="var(--accent)" stroke-width="2" stroke-dasharray="10 10" class="anim-trace drive-anim propagating-wave" opacity="0" filter="url(#amber-glow)" />
      </g>

      <!-- Flux Bias Line -->
      <g class="comp-group hoverable" id="flux-group" data-info="Flux Bias Line: A fast current pulse through this line generates a magnetic flux that threads the SQUID loop, tuning the qubit's frequency in real-time.">
        <path d="M 240 150 Q 260 150 260 170 L 260 250" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-dasharray="4 4" class="static-trace" />
        <path d="M 240 150 Q 260 150 260 170 L 260 250" fill="none" stroke="var(--accent)" stroke-width="3" stroke-dasharray="4 4" class="anim-trace flux-anim" opacity="0" filter="url(#amber-glow)" />
      </g>

      <!-- Shunt Capacitor (Cross shape) -->
      <g class="comp-group hoverable" id="capacitor-group" data-info="Shunt Capacitor (Cross): Massive superconducting pads provide large capacitance (~100 fF) to flatten the charge dispersion curve, rendering the qubit immune to charge noise.">
        <!-- Top Pad Wireframe -->
        <path d="M 170 50 L 230 50 L 230 140 L 170 140 Z" fill="rgba(255,176,0,0.02)" stroke="var(--text-muted)" stroke-width="1.5" class="capacitor-trace" />
        <!-- Bottom Pad Wireframe -->
        <path d="M 170 160 L 230 160 L 230 250 L 170 250 Z" fill="rgba(255,176,0,0.02)" stroke="var(--text-muted)" stroke-width="1.5" class="capacitor-trace" />
        
        <!-- Animated charge glow inside pads -->
        <path d="M 175 55 L 225 55 L 225 135 L 175 135 Z" fill="var(--accent)" class="anim-trace capacitor-anim charge-glow" opacity="0" filter="url(#amber-glow)" />
        <path d="M 175 165 L 225 165 L 225 245 L 175 245 Z" fill="var(--accent)" class="anim-trace capacitor-anim charge-glow-alt" opacity="0" filter="url(#amber-glow)" />
      </g>

      <!-- Josephson Junctions (SQUID loop) -->
      <g class="comp-group hoverable" id="squid-group" data-info="Josephson Junctions (SQUID loop): Two ultra-thin Al/AlOx/Al junctions in a loop form a tunable non-linear inductor. This non-linearity is what makes the transmon a qubit rather than a harmonic oscillator.">
        <!-- Loop connections -->
        <line x1="190" y1="140" x2="190" y2="160" stroke="var(--text-main)" stroke-width="1.5" class="squid-trace" />
        <line x1="210" y1="140" x2="210" y2="160" stroke="var(--text-main)" stroke-width="1.5" class="squid-trace" />
        
        <!-- Junction X marks -->
        <g stroke="var(--text-main)" stroke-width="1.5" class="squid-trace">
          <line x1="185" y1="145" x2="195" y2="155" />
          <line x1="195" y1="145" x2="185" y2="155" />
        </g>
        <g stroke="var(--text-main)" stroke-width="1.5" class="squid-trace">
          <line x1="205" y1="145" x2="215" y2="155" />
          <line x1="215" y1="145" x2="205" y2="155" />
        </g>

        <!-- Animated SQUID glow -->
        <circle cx="200" cy="150" r="15" fill="none" stroke="var(--accent)" stroke-width="2" class="anim-trace squid-anim squid-pulse" opacity="0" filter="url(#amber-glow)" />
      </g>

    </svg>
  </div>
  
  <HoverInfoPanel defaultText="Hover over a wireframe component to reveal its function in the transmon architecture." />
</InteractiveBoard>

<style>
  .transmon-graphic {
    background: transparent;
    padding: 1rem;
    display: flex;
    justify-content: center;
  }
  
  .hud-label {
    font-family: 'Fira Code', monospace;
    font-size: 10px;
    fill: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hoverable {
    cursor: crosshair;
  }

  /* Base states */
  .capacitor-trace, .static-trace, .squid-trace {
    transition: all 0.3s ease;
  }
  
  .anim-trace {
    transition: opacity 0.3s ease;
  }

  /* Hover States */
  .hoverable:hover .capacitor-trace,
  .hoverable:hover .static-trace,
  .hoverable:hover .squid-trace {
    stroke: var(--accent);
  }

  /* Reveal animations on hover */
  #readout-group:hover .readout-anim { opacity: 0.8; }
  #drive-group:hover .drive-anim { opacity: 0.8; }
  #flux-group:hover .flux-anim { opacity: 0.8; }
  #capacitor-group:hover .capacitor-anim { opacity: 0.15; }
  #squid-group:hover .squid-anim { opacity: 1; }

  /* Keyframe Animations */
  
  /* Standing Wave: Oscillates dash offset back and forth quickly */
  .standing-wave {
    stroke-dasharray: 4 4;
    animation: standingWaveAnim 0.5s infinite alternate linear;
  }
  @keyframes standingWaveAnim {
    0% { stroke-dashoffset: 0; stroke-width: 1; }
    100% { stroke-dashoffset: 8; stroke-width: 3; }
  }

  /* Propagating Wave: Sine-like dashed line moving forward */
  .propagating-wave {
    animation: propagateAnim 1s infinite linear;
  }
  @keyframes propagateAnim {
    0% { stroke-dashoffset: 20; }
    100% { stroke-dashoffset: 0; }
  }

  /* SQUID Pulse: Breathing glow simulating tunneling/non-linearity */
  .squid-pulse {
    animation: squidPulseAnim 1.5s infinite alternate ease-in-out;
  }
  @keyframes squidPulseAnim {
    0% { transform: scale(0.8); transform-origin: 200px 150px; opacity: 0.2; stroke-width: 1; }
    100% { transform: scale(1.2); transform-origin: 200px 150px; opacity: 1; stroke-width: 3; }
  }

  /* Flux Line pulsing */
  .flux-anim {
    animation: fluxFlow 0.5s infinite linear;
  }
  @keyframes fluxFlow {
    to { stroke-dashoffset: -8; }
  }

  /* Charge Oscillations across the capacitor pads */
  .charge-glow {
    animation: chargeOscillate 2s infinite alternate ease-in-out;
  }
  .charge-glow-alt {
    animation: chargeOscillateAlt 2s infinite alternate ease-in-out;
  }
  @keyframes chargeOscillate {
    0% { opacity: 0.05; }
    100% { opacity: 0.3; }
  }
  @keyframes chargeOscillateAlt {
    0% { opacity: 0.3; }
    100% { opacity: 0.05; }
  }
</style>
