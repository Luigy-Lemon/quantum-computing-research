---
// ChandelierSchematic.astro
// Dilution Refrigerator schematic — cryogenic engineering HUD
// Temperature descent from 300K to 15mK quantum plane
---

<div class="cryo-schematic" role="navigation" aria-label="Quantum Hardware Stack">

  <!-- HUD Frame Corners -->
  <div class="hud-frame" aria-hidden="true">
    <div class="frame-corner fc-tl"></div>
    <div class="frame-corner fc-tr"></div>
    <div class="frame-corner fc-bl"></div>
    <div class="frame-corner fc-br"></div>
  </div>

  <!-- Ambient Temperature Gradient -->
  <div class="temp-gradient" aria-hidden="true"></div>

  <!-- Grid Overlay -->
  <div class="grid-overlay" aria-hidden="true"></div>

  <!-- Thermal Spine & Coolant Flow -->
  <div class="thermal-spine" aria-hidden="true">
    <div class="coolant-line coolant-down"></div>
    <div class="coolant-line coolant-up"></div>
    <div class="coolant-line coolant-sync"></div>
  </div>

  <!-- ═══ STAGE: 300 K ═══ -->
  <div class="stage fridge-stage" data-stage="300k" style="--stage-color: #ffb000;">
    <div class="stage-header">
      <div class="temp-badge">
        <span class="temp-value">300 K</span>
        <span class="temp-unit">Room Temp</span>
      </div>
      <div class="stage-rule"></div>
      <span class="stage-label">Instrumentation Rack</span>
    </div>
    <div class="cards">
      <a href="/classical-control" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">SYS-RF01</span>
          <span class="card-spec">4–8 GHz</span>
        </div>
        <div class="card-body">
          <div class="led"></div>
          <div class="card-info">
            <h4>RF Signal Generator</h4>
            <p>AWG waveform synthesis · I/Q modulation</p>
          </div>
        </div>
      </a>

      <a href="/classical-control" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">DSP-RX02</span>
          <span class="card-spec">14b · 8GSPS</span>
        </div>
        <div class="card-body">
          <div class="led"></div>
          <div class="card-info">
            <h4>RFSoC Digitizer</h4>
            <p>IQ demodulation · readout discrimination</p>
          </div>
        </div>
      </a>

      <a href="/classical-control" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">FPGA-DEC</span>
          <span class="card-spec">MWPM &lt;1µs</span>
        </div>
        <div class="card-body">
          <div class="led anim-pulse"></div>
          <div class="card-info">
            <h4>FPGA Decoder</h4>
            <p>Real-time syndrome → correction</p>
          </div>
        </div>
      </a>

      <a href="/neutral-atoms" class="hw-card card-neutral-only">
        <div class="card-rail" style="background: var(--accent-orange, #d97706);"></div>
        <div class="card-header">
          <span class="card-id" style="color: var(--accent-orange, #d97706);">VAC-MOT</span>
          <span class="card-spec">Rb-87 cell</span>
        </div>
        <div class="card-body">
          <div class="led anim-blink" style="background: var(--accent-orange, #d97706); box-shadow: 0 0 8px var(--accent-orange, #d97706);"></div>
          <div class="card-info">
            <h4>Rydberg Vacuum Cell</h4>
            <p>Optical tweezers array · 300K Chamber</p>
          </div>
        </div>
      </a>

      <a href="/photonic-computing" class="hw-card card-photonic-300k-only">
        <div class="card-rail" style="background: var(--accent-pink, #db2777);"></div>
        <div class="card-header">
          <span class="card-id" style="color: var(--accent-pink, #db2777);">PH-MZI</span>
          <span class="card-spec">SiN Fabric</span>
        </div>
        <div class="card-body">
          <div class="led anim-pulse" style="background: var(--accent-pink, #db2777); box-shadow: 0 0 8px var(--accent-pink, #db2777);"></div>
          <div class="card-info">
            <h4>Silicon Nitride Waveguide MZI</h4>
            <p>All-optical room-temperature logic</p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Cooling Step: 300K → 50K -->
  <div class="cooling-step" aria-hidden="true">
    <div class="cooling-track"></div>
    <span class="cooling-ratio">×6</span>
    <div class="cooling-track"></div>
  </div>

  <!-- ═══ STAGE: 50 K ═══ -->
  <div class="stage fridge-stage" data-stage="300k" style="--stage-color: #e69d00;">
    <div class="stage-header">
      <div class="temp-badge">
        <span class="temp-value">50 K</span>
        <span class="temp-unit">1st Shield</span>
      </div>
      <div class="stage-rule"></div>
      <span class="stage-label">Radiation Shield</span>
    </div>
    <div class="cards">
      <a href="/microwave-wiring" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">ATT-50K</span>
          <span class="card-spec">−20 dB</span>
        </div>
        <div class="card-body">
          <div class="led"></div>
          <div class="card-info">
            <h4>Cryogenic Attenuator</h4>
            <p>Thermalizes 300K Johnson noise</p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Cooling Step: 50K → 4K -->
  <div class="cooling-step" aria-hidden="true">
    <div class="cooling-track"></div>
    <span class="cooling-ratio">×12.5</span>
    <div class="cooling-track"></div>
  </div>

  <!-- ═══ STAGE: 4 K ═══ -->
  <div class="stage fridge-stage" data-stage="4k" style="--stage-color: #cda434;">
    <div class="stage-header">
      <div class="temp-badge">
        <span class="temp-value">4 K</span>
        <span class="temp-unit">Pulse Tube</span>
      </div>
      <div class="stage-rule"></div>
      <span class="stage-label">Pulse Tube Stage</span>
    </div>
    <div class="cards">
      <a href="/microwave-wiring" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">ATT-4K</span>
          <span class="card-spec">−10 dB</span>
        </div>
        <div class="card-body">
          <div class="led"></div>
          <div class="card-info">
            <h4>Cryogenic Attenuator</h4>
            <p>NbTi coax transition thermal sink</p>
          </div>
        </div>
      </a>

      <a href="/readout" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">AMP-HEMT</span>
          <span class="card-spec">+40 dB</span>
        </div>
        <div class="card-body">
          <div class="led anim-pulse"></div>
          <div class="card-info">
            <h4>HEMT Amplifier</h4>
            <p>Low-noise cryo amp · T_n ≈ 2 K</p>
          </div>
        </div>
      </a>

      <a href="/trapped-ions" class="hw-card card-ion-only">
        <div class="card-rail" style="background: var(--accent-cyan, #0891b2);"></div>
        <div class="card-header">
          <span class="card-id" style="color: var(--accent-cyan, #0891b2);">QCCD-ION</span>
          <span class="card-spec">Yb-171 trap</span>
        </div>
        <div class="card-body">
          <div class="led anim-blink" style="background: var(--accent-cyan, #0891b2); box-shadow: 0 0 8px var(--accent-cyan, #0891b2);"></div>
          <div class="card-info">
            <h4>QCCD Paul Trap Array</h4>
            <p>4K Cryo-chamber · electrostatic controls</p>
          </div>
        </div>
      </a>

      <a href="/photonic-computing" class="hw-card card-photonic-4k-only">
        <div class="card-rail" style="background: var(--accent-pink, #db2777);"></div>
        <div class="card-header">
          <span class="card-id" style="color: var(--accent-pink, #db2777);">DET-SNSPD</span>
          <span class="card-spec">NbN Nanowire</span>
        </div>
        <div class="card-body">
          <div class="led anim-blink" style="background: var(--accent-pink, #db2777); box-shadow: 0 0 8px var(--accent-pink, #db2777);"></div>
          <div class="card-info">
            <h4>SNSPD Detector Array</h4>
            <p>1-4K Cryostat readout · &gt;99% efficiency</p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Cooling Step: 4K → 800mK -->
  <div class="cooling-step" aria-hidden="true">
    <div class="cooling-track"></div>
    <span class="cooling-ratio">×5</span>
    <div class="cooling-track"></div>
  </div>

  <!-- ═══ STAGE: 800 mK ═══ -->
  <div class="stage fridge-stage" data-stage="4k" style="--stage-color: #8ca0b4;">
    <div class="stage-header">
      <div class="temp-badge">
        <span class="temp-value">800 mK</span>
        <span class="temp-unit">Still</span>
      </div>
      <div class="stage-rule"></div>
      <span class="stage-label">Still Plate</span>
    </div>
    <div class="cards">
      <a href="/microwave-wiring" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">ISO-C1</span>
          <span class="card-spec">4–8 GHz</span>
        </div>
        <div class="card-body">
          <div class="led"></div>
          <div class="card-info">
            <h4>Isolator Array</h4>
            <p>3-port ferrite · &gt;20 dB blockade</p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Cooling Step: 800mK → 100mK -->
  <div class="cooling-step" aria-hidden="true">
    <div class="cooling-track"></div>
    <span class="cooling-ratio">×8</span>
    <div class="cooling-track"></div>
  </div>

  <!-- ═══ STAGE: 100 mK ═══ -->
  <div class="stage fridge-stage" data-stage="15mk" style="--stage-color: #6496c8;">
    <div class="stage-header">
      <div class="temp-badge">
        <span class="temp-value">100 mK</span>
        <span class="temp-unit">Cold Plate</span>
      </div>
      <div class="stage-rule"></div>
      <span class="stage-label">Cold Plate</span>
    </div>
    <div class="cards">
      <a href="/microwave-wiring" class="hw-card">
        <div class="card-rail"></div>
        <div class="card-header">
          <span class="card-id">FIL-ECC</span>
          <span class="card-spec">LP ~12GHz</span>
        </div>
        <div class="card-body">
          <div class="led"></div>
          <div class="card-info">
            <h4>Eccosorb IR Filter</h4>
            <p>Absorptive block for stray IR photons</p>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Cooling Step: 100mK → 15mK -->
  <div class="cooling-step" aria-hidden="true">
    <div class="cooling-track"></div>
    <span class="cooling-ratio">×6.7</span>
    <div class="cooling-track"></div>
  </div>

  <!-- ═══ STAGE: 15 mK — Quantum Plane ═══ -->
  <div class="stage stage--quantum fridge-stage" data-stage="15mk" style="--stage-color: #64b4ff;">
    <div class="stage-header">
      <div class="temp-badge temp-badge--cold">
        <span class="temp-value temp-value--cold">15 mK</span>
        <span class="temp-unit temp-unit--cold">Mixing Chamber</span>
      </div>
      <div class="stage-rule stage-rule--cold"></div>
      <span class="stage-label stage-label--cold">Quantum Plane</span>
    </div>
    <div class="cards">
      <div class="mu-shield">
        <div class="shield-tag">
          <span class="shield-icon">⬢</span> µ-METAL MAGNETIC SHIELDING
        </div>
        <div class="shield-inner">
          <a href="/physics" class="hw-card hw-card--quantum card-transmon-only">
            <div class="card-rail card-rail--quantum"></div>
            <div class="card-header">
              <span class="card-id card-id--quantum">QPU-CORE</span>
              <span class="card-spec">f₀₁ 5.2 GHz</span>
            </div>
            <div class="card-body">
              <div class="led anim-blink"></div>
              <div class="card-info">
                <h4>Transmon Array</h4>
                <p>Al/AlOx/Al · T₁ ~ 80µs · T₂ ~ 60µs</p>
              </div>
            </div>
          </a>

          <a href="/topological-qubits" class="hw-card hw-card--quantum card-topological-only">
            <div class="card-rail card-rail--quantum"></div>
            <div class="card-header">
              <span class="card-id card-id--quantum">QPU-TOPO</span>
              <span class="card-spec">Majorana 2</span>
            </div>
            <div class="card-body">
              <div class="led anim-blink"></div>
              <div class="card-info">
                <h4>Majorana 2 Array</h4>
                <p>InAs/Pb Nanowires · T_coh ~ 20s</p>
              </div>
            </div>
          </a>

          <a href="/readout" class="hw-card hw-card--quantum">
            <div class="card-rail card-rail--quantum"></div>
            <div class="card-header">
              <span class="card-id card-id--quantum">AMP-TWPA</span>
              <span class="card-spec">+20 dB</span>
            </div>
            <div class="card-body">
              <div class="led anim-pulse"></div>
              <div class="card-info">
                <h4>TWPA</h4>
                <p>Quantum-limited · T_n → ½ℏω/k_B</p>
              </div>
            </div>
          </a>

          <a href="/interconnects" class="hw-card hw-card--quantum">
            <div class="card-rail card-rail--quantum"></div>
            <div class="card-header">
              <span class="card-id card-id--quantum">TD-EO</span>
              <span class="card-spec">η ~ 10⁻²</span>
            </div>
            <div class="card-body">
              <div class="led anim-pulse-alt"></div>
              <div class="card-info">
                <h4>E/O Transducer</h4>
                <p>Microwave ↔ Optical 1550nm cavity</p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ════════════════════════════════════════
     CONTAINER — Temperature Gradient HUD
     ════════════════════════════════════════ */
  .cryo-schematic, .cryo-schematic *, .cryo-schematic *::before, .cryo-schematic *::after {
    box-sizing: border-box; margin: 0; padding: 0;
  }

  .cryo-schematic {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 2.5rem 1.5rem 2rem 4.5rem;
    font-family: 'Inter', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow: hidden;
    border-radius: 6px;

    background:
      linear-gradient(180deg,
        #0c0a06 0%,
        #0a0908 18%,
        #080a0a 40%,
        #060a10 70%,
        #040a14 100%
      );

    border: 1px solid rgba(255, 176, 0, 0.12);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.7),
      0 0 1px rgba(255, 176, 0, 0.15);
  }

  /* Ambient temperature glow */
  .temp-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      rgba(255, 176, 0, 0.04) 0%,
      rgba(255, 176, 0, 0.02) 15%,
      transparent 35%,
      transparent 55%,
      rgba(100, 180, 255, 0.02) 75%,
      rgba(100, 180, 255, 0.06) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Technical grid overlay */
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
    z-index: 0;
  }

  /* ════════════════════════════════════════
     HUD FRAME CORNERS
     ════════════════════════════════════════ */
  .hud-frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
  }

  .frame-corner {
    position: absolute;
    width: 18px;
    height: 18px;
  }

  .fc-tl { top: 6px; left: 6px; border-top: 2px solid rgba(255, 176, 0, 0.3); border-left: 2px solid rgba(255, 176, 0, 0.3); }
  .fc-tr { top: 6px; right: 6px; border-top: 2px solid rgba(255, 176, 0, 0.3); border-right: 2px solid rgba(255, 176, 0, 0.3); }
  .fc-bl { bottom: 6px; left: 6px; border-bottom: 2px solid rgba(100, 180, 255, 0.3); border-left: 2px solid rgba(100, 180, 255, 0.3); }
  .fc-br { bottom: 6px; right: 6px; border-bottom: 2px solid rgba(100, 180, 255, 0.3); border-right: 2px solid rgba(100, 180, 255, 0.3); }

  /* ════════════════════════════════════════
     THERMAL SPINE & COOLANT FLOW
     ════════════════════════════════════════ */
  .thermal-spine {
    position: absolute;
    left: 30px;
    top: 24px;
    bottom: 0;
    width: 18px;
    z-index: 1;
    display: flex;
    justify-content: space-evenly;
    padding: 0 2px;
  }

  .coolant-line {
    width: 2px;
    height: 100%;
    border-radius: 1px;
  }

  /* He-3 downflow — amber to blue gradient */
  .coolant-down {
    background: linear-gradient(180deg,
      rgba(255, 176, 0, 0.6) 0%,
      rgba(200, 160, 50, 0.3) 40%,
      rgba(100, 150, 200, 0.3) 70%,
      rgba(100, 180, 255, 0.5) 100%
    );
    background-size: 100% 200%;
    animation: flowDown 2.5s linear infinite;
    box-shadow: 0 0 6px rgba(255, 176, 0, 0.15);
  }

  /* He-4 return — blue to amber gradient */
  .coolant-up {
    background: linear-gradient(0deg,
      rgba(100, 180, 255, 0.5) 0%,
      rgba(100, 150, 200, 0.3) 30%,
      rgba(200, 160, 50, 0.2) 70%,
      rgba(255, 176, 0, 0.3) 100%
    );
    background-size: 100% 200%;
    animation: flowUp 3.5s linear infinite;
    box-shadow: 0 0 6px rgba(100, 180, 255, 0.1);
  }

  /* Sync / data line — dashed */
  .coolant-sync {
    background: repeating-linear-gradient(180deg,
      rgba(255, 255, 255, 0.12) 0px,
      rgba(255, 255, 255, 0.12) 3px,
      transparent 3px,
      transparent 10px
    );
    animation: flowDown 0.8s linear infinite;
  }

  @keyframes flowDown { from { background-position: 0 -200%; } to { background-position: 0 0%; } }
  @keyframes flowUp { from { background-position: 0 200%; } to { background-position: 0 0%; } }

  /* ════════════════════════════════════════
     STAGE LAYOUT
     ════════════════════════════════════════ */
  .stage {
    position: relative;
    padding: 2.25rem 0;
    z-index: 2;
  }

  /* Connector from spine to stage header */
  .stage::before {
    content: '';
    position: absolute;
    left: calc(-4.5rem + 48px);
    top: 2.15rem;
    width: calc(4.5rem - 48px);
    height: 1px;
    background: var(--stage-color);
    opacity: 0.5;
    box-shadow: 0 0 6px var(--stage-color);
  }

  /* Hover / active states */
  .fridge-stage:hover,
  .fridge-stage.active {
    background: linear-gradient(90deg,
      rgba(255, 255, 255, 0.025) 0%,
      transparent 60%
    );
    border-radius: 3px;
  }

  .fridge-stage:hover .temp-value,
  .fridge-stage.active .temp-value {
    text-shadow: 0 0 20px var(--stage-color), 0 0 40px var(--stage-color);
  }

  .fridge-stage:hover .stage-rule,
  .fridge-stage.active .stage-rule {
    opacity: 0.7;
  }

  /* ════════════════════════════════════════
     STAGE HEADERS
     ════════════════════════════════════════ */
  .stage-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .temp-badge {
    display: flex;
    flex-direction: column;
    min-width: 90px;
  }

  .temp-value {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.7rem;
    font-weight: 900;
    color: var(--stage-color);
    text-shadow: 0 0 14px var(--stage-color);
    line-height: 1;
    letter-spacing: -0.5px;
    transition: text-shadow 0.3s ease;
  }

  .temp-unit {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .stage-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--stage-color), transparent 80%);
    opacity: 0.35;
    transition: opacity 0.3s ease;
  }

  .stage-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.32);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    white-space: nowrap;
  }

  /* ════════════════════════════════════════
     COOLING STEP ANNOTATIONS
     ════════════════════════════════════════ */
  .cooling-step {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 1rem 0.35rem 4.5rem;
    position: relative;
    z-index: 2;
  }

  .cooling-track {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 176, 0, 0.12), rgba(100, 180, 255, 0.12));
  }

  .cooling-ratio {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.64rem;
    color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    letter-spacing: 0.1em;
  }

  /* ════════════════════════════════════════
     HARDWARE CARDS
     ════════════════════════════════════════ */
  .cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-left: 0.25rem;
  }

  .hw-card {
    display: grid;
    grid-template-columns: 135px 1fr;
    align-items: center;
    position: relative;
    text-decoration: none;
    border-radius: 3px;
    overflow: hidden;
    cursor: pointer;

    background: rgba(255, 255, 255, 0.018);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-top: 1px solid rgba(255, 255, 255, 0.08);

    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
